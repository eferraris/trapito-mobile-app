# Copiá este archivo a ".env" y completá con los valores de tu proyecto Supabase.
# Settings -> API en el dashboard de Supabase.
# El prefijo EXPO_PUBLIC_ es necesario para que Expo exponga la variable al cliente.

EXPO_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_PUBLIC_KEY

# Google Maps API key para Android. Se inyecta en el build nativo vía app.config.js.
# Sin prefijo EXPO_PUBLIC_ a propósito: solo se usa en tiempo de build, no se
# expone en el bundle JS. Creá la key en Google Cloud Console y restringila
# (Android: por package + SHA-1). iOS no la necesita: usa Apple Maps.
GOOGLE_MAPS_ANDROID_KEY=TU_ANDROID_GOOGLE_MAPS_API_KEY
